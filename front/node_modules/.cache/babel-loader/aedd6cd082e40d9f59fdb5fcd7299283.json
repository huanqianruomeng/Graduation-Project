nput\"\n            v-if=\"tableName == 'jiaoshi'\"\n          >\n            <el-input\n              v-model=\"ruleForm.mima\"\n              autocomplete=\"off\"\n              placeholder=\"密码\"\n              type=\"password\"\n              #elsetype=\"text\"\n            />\n          </el-form-item>\n          <!-- <div v-if=\"tableName=='jiaoshi'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">教师姓名</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.jiaoshixingming\" class=\"input\" type=\"text\" placeholder=\"教师姓名\">\n\t\t\t   </div>\n\t\t\t </div> -->\n          <el-form-item\n            label=\"教师姓名\"\n            class=\"input\"\n            v-if=\"tableName == 'jiaoshi'\"\n          >\n            <el-input\n              v-model=\"ruleForm.jiaoshixingming\"\n              autocomplete=\"off\"\n              placeholder=\"教师姓名\"\n            />\n          </el-form-item>\n          <!-- <div v-if=\"tableName=='jiaoshi'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">学院</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.xueyuan\" class=\"input\" type=\"text\" placeholder=\"学院\">\n\t\t\t   </div>\n\t\t\t </div> -->\n          <el-form-item\n            label=\"学院\"\n            class=\"input\"\n            v-if=\"tableName == 'jiaoshi'\"\n          >\n            <el-input\n              v-model=\"ruleForm.xueyuan\"\n              autocomplete=\"off\"\n              placeholder=\"学院\"\n            />\n          </el-form-item>\n          <!-- <div v-if=\"tableName=='jiaoshi'\" class=\"input-group\">\n\t\t\t   <div class=\"label\">职称</div>\n\t\t\t   <div class=\"input-container\">\n\t\t\t     <input v-model=\"ruleForm.zhicheng\" class=\"input\" type=\"text\" placeholder=\"职称\">\n\t\t\t   </div>\n\t\t\t </div> -->\n          <el-form-item\n            label=\"职称\"\n            class=\"input\"\n            v-if=\"tableName == 'jiaoshi'\"\n          >\n            <el-input